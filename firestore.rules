rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (matches Firebase Auth UID)
    // Fields:
    //   - firstName: string
    //   - lastName: string
    //   - dob: string
    //   - time: string
    //   - place: string
    //   - code: string
    //   - digits: list of numbers
    //   - biorhythm: map
    //   - frequency: number
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'dob', 'time', 'place', 'code', 'digits', 'biorhythm', 'frequency']) &&
             data.firstName is string && data.firstName.size() < 100 &&
             data.lastName is string && data.lastName.size() < 100 &&
             data.dob is string && data.dob.size() < 20 &&
             data.time is string && data.time.size() < 20 &&
             data.place is string && data.place.size() < 100 &&
             data.code is string && data.code.size() < 50 &&
             data.digits is list && data.digits.size() == 6 &&
             data.biorhythm is map &&
             data.frequency is number;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isOwner(userId);
    }
  }
}
