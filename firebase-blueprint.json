{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile containing SFVM calculation data",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "dob": { "type": "string" },
        "time": { "type": "string" },
        "place": { "type": "string" },
        "code": { "type": "string" },
        "digits": {
          "type": "array",
          "items": { "type": "number" }
        },
        "biorhythm": {
          "type": "object",
          "properties": {
            "physical": { "type": "number" },
            "emotional": { "type": "number" },
            "intellectual": { "type": "number" },
            "intuitive": { "type": "number" }
          }
        },
        "frequency": { "type": "number" }
      },
      "required": ["firstName", "lastName", "dob", "time", "place", "code", "digits", "biorhythm", "frequency"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles stored by their Firebase Auth UID"
    }
  }
}
